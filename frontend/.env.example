# Backend API base URL.
# Local dev: leave unset (defaults to http://localhost:8000 in code).
# Vercel: set this to your Azure backend URL, e.g. https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# API key matching the backend's LUCID_API_KEY.
# Local dev: leave unset (backend auth is disabled without LUCID_API_KEY).
# Vercel: set to the same value as the backend's LUCID_API_KEY.
NEXT_PUBLIC_LUCID_API_KEY=
