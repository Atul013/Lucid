ALLOWED_ORIGINS=http://localhost:3000

# --- Security (see backend/app/security.py) ---
# Shared secret for API auth. Leave empty in local dev (auth disabled).
# In production set a long random value and give the frontend the same
# value as NEXT_PUBLIC_LUCID_API_KEY. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
LUCID_API_KEY=
# Requests per client IP per minute before 429s (default 300)
RATE_LIMIT_PER_MINUTE=300
# Max request payload in bytes (default 5 MB)
MAX_BODY_BYTES=5242880
# Set to 0 to silence the per-request audit log line
LUCID_AUDIT_LOG=1

# Where the OAuth callback redirects the user back to (the frontend)
FRONTEND_URL=http://localhost:3000

# Google OAuth (filled after setting up GCP project)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# LLM — NVIDIA NIM (OpenAI-compatible). Get a key at build.nvidia.com
NVIDIA_API_KEY=
LLM_MODEL=minimaxai/minimax-m3

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
